##In this query I worked with a digital media store and includes tables for artists, albums, media tracks, invoices, and customers.

-- #1 Show Customers (their full names, customer ID, and country) who are not in the US. (Hint: != or <> can be used to say "is not equal to").

SELECT CONCAT (FirstName,' ', LastName) AS Full_name
,Customerid
,Country
FROM customers
WHERE Country != "USA"
ORDER BY Customerid;


--#2 Show only the Customers from Brazil.

SELECT CONCAT (FirstName,' ', LastName) AS Full_name
,Customerid
,Country
FROM customers
WHERE Country = "Brazil"
ORDER BY Customerid;

--#3 Find the Invoices of customers who are from Brazil. The resulting table should show the customer's full name, Invoice ID, Date of the invoice, and billing country.

SELECT  DISTINCT  I.InvoiceId
,I.invoiceDate
,I.BillingCountry
,CONCAT (C.FirstName,' ', C.LastName) AS Full_name
FROM customers C 
JOIN playlist_track PT
ON C.Customerid = PT.Trackid
JOIN invoice_items IT
ON PT.Trackid = IT.invoiceid
JOIN invoices I 
on IT.invoiceid = I.Customerid
WHERE C.country = "Brazil";


SELECT CONCAT (C.FirstName,' ', C.LastName) AS Full_name
,I.InvoiceId
,I.invoiceDate
,I.BillingCountry
FROM invoices as I
LEFT JOIN customers as C
on I.CustomerId = C.CustomerId 
WHERE I.BillingCountry = "Brazil";

-- #4 Show the Employees who are Sales Agents.

SELECT *
FROM employees
WHERE Title LIKE "%Sales Sup%";


-- #5 Find a unique/distinct list of billing countries from the Invoice table.

SELECT DISTINCT BillingCountry
FROM invoices
ORDER BY BillingCountry;


--#6 Provide a query that shows the invoices associated with each sales agent. The resulting table should include the Sales Agent's full name. 


SELECT E.Employeeid
,CONCAT (E.FirstName,' ', E.LastName) AS Full_name
,I.Invoiceid
FROM invoices as I
LEFT JOIN customers as C
on I.CustomerId = C.CustomerId
LEFT JOIN employees E
ON C.SupportRepid = E.Employeeid
GROUP BY I.Invoiceid
ORDER BY Full_name;


SELECT CONCAT (E.FirstName,' ', E.LastName) AS Full_name
,I.Invoiceid
FROM employees E
JOIN customers C 
ON C.SupportRepid = E.Employeeid
JOIN invoices I
ON I.Customerid = C.Customerid;

-- #7 Show the Invoice Total, Customer name, Country, and Sales Agent name for all invoices and customers.

SELECT I.Total
,CONCAT (C.FirstName,' ', C.LastName) AS Cust_name
,C.Country
,I.Invoiceid
,CONCAT (E.FirstName,' ', E.LastName) AS Full_name
FROM employees E
JOIN customers C 
ON C.SupportRepid = E.Employeeid
JOIN invoices I
ON I.Customerid = C.Customerid;

--#8 How many Invoices were there in 2009?

SELECT COUNT (Invoiceid)
FROM invoices 
WHERE InvoiceDate LIKE "%2009%";


-- #9 What are the total sales for 2009?
SELECT SUM (Total)
FROM invoices 
WHERE InvoiceDate LIKE "%2009%";


--#10 Write a query that includes the purchased track name with each invoice line ID.

SELECT T.Name
,IT.InvoiceLineid
FROM tracks T 
JOIN invoice_items IT 
ON T.Trackid = IT.Trackid ;

-- #11 Write a query that includes the purchased track name AND artist name with each invoice line ID.

SELECT T.Name
,A.Name
,IT.InvoiceLineid
FROM invoice_items IT 
LEFT JOIN tracks T
ON IT.Trackid = T.Trackid
LEFT JOIN artists A
ON A.artistid = T.Albumid;



-- #12S how the total sales made by each sales agent.

SELECT CONCAT (E.FirstName,' ', E.LastName) AS Full_name
,Sum (I.Total) AS total_sold
,E.Title
FROM employees E
JOIN customers C 
ON E.Employeeid = C.SupportRepid
JOIN invoices I 
ON I.Customerid = C.Customerid
WHERE E.Title = "Sales Support Agent"
GROUP BY  CONCAT (E.FirstName,' ', E.LastName);



--#14 Which sales agent made the most dollars in sales in 2009?

SELECT CONCAT (E.FirstName,' ', E.LastName) AS Full_name
,Sum (I.Total) AS total_sold
,E.Title
FROM employees E
JOIN customers C 
ON E.Employeeid = C.SupportRepid
JOIN invoices I 
ON I.Customerid = C.Customerid
WHERE E.Title = "Sales Support Agent"
AND I.InvoiceDate LIKE "%2009%"
GROUP BY  CONCAT (E.FirstName,' ', E.LastName)
ORDER BY total_sold DESC
LIMIT 1;

-- #15 show the total sold by country 

SELECT I.invoiceid
,I.Total
,C.Country
FROM invoices I 
JOIN customers C
on I.Customerid = C.Customerid 
GROUP BY C.Country
ORDER BY I.Total DESC;

-- #16 The total of songs for playlist 

SELECT P.Name AS playlist
,COUNT (T.Name) AS song
FROM tracks T
JOIN playlist_track PT
ON T.Trackid = PT.Trackid
JOIN playlists P
ON PT.Playlistid = P.Playlistid 
GROUP BY playlist
ORDER BY song DESC;

-- #17 the artist that sold more

SELECT A.Name AS ArtistName
, ROUND (SUM(I.total)) AS TotalSales
FROM artists A
JOIN tracks T
  ON A.Artistid = T.AlbumId
JOIN invoice_items IT
  ON T.TrackId = IT.TrackId
JOIN invoices I
  ON IT.InvoiceId = I.InvoiceId
GROUP BY A.Name
ORDER BY TotalSales DESC;


SELECT I.Total
,IT.Trackid
,T.name
,A.Name AS artistName
FROM invoices I
JOIN invoice_items IT
ON I.Invoiceid = IT.Invoiceid
JOIN tracks T
ON IT.Trackid = T.Trackid
JOIN artists A
ON T.Albumid = A.Artistid
WHERE artistName = "The Police"
ORDER BY IT.Trackid ASC


